{
  "name": "Certificate",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "course_id": {
      "type": "string"
    },
    "course_title": {
      "type": "string"
    },
    "verification_code": {
      "type": "string"
    },
    "issue_date": {
      "type": "string",
      "format": "date"
    },
    "issuer_name": {
      "type": "string"
    },
    "skills_certified": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "revoked"],
      "default": "active"
    }
  },
  "required": ["user_email", "verification_code"]
}
