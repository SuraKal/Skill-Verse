{
  "name": "Course",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "instructor_email": {
      "type": "string"
    },
    "instructor_name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "programming",
        "design",
        "business",
        "language",
        "music",
        "science",
        "math",
        "writing",
        "marketing",
        "other"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "cover_image": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "archived"],
      "default": "draft"
    },
    "enrollment_count": {
      "type": "number",
      "default": 0
    },
    "rating": {
      "type": "number",
      "default": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title"]
}
