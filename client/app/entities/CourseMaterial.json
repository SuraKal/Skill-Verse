{
  "name": "CourseMaterial",
  "type": "object",
  "properties": {
    "course_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["document", "video", "quiz", "link"]
    },
    "content": {
      "type": "string"
    },
    "file_url": {
      "type": "string"
    },
    "order": {
      "type": "number",
      "default": 0
    }
  },
  "required": ["course_id", "title", "type"]
}
