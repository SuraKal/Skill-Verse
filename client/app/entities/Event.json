{
  "name": "Event",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "organizer_email": {
      "type": "string"
    },
    "organizer_name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "workshop",
        "meetup",
        "webinar",
        "hackathon",
        "conference",
        "other"
      ]
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "end_date": {
      "type": "string",
      "format": "date-time"
    },
    "location": {
      "type": "string"
    },
    "is_virtual": {
      "type": "boolean",
      "default": false
    },
    "meeting_link": {
      "type": "string"
    },
    "cover_image": {
      "type": "string"
    },
    "max_attendees": {
      "type": "number"
    },
    "registration_count": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": ["upcoming", "ongoing", "completed", "cancelled"],
      "default": "upcoming"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title", "date"]
}
