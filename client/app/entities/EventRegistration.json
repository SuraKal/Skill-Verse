{
  "name": "EventRegistration",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_title": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["registered", "attended", "cancelled"],
      "default": "registered"
    }
  },
  "required": ["event_id", "user_email"]
}
