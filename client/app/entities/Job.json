{
  "name": "Job",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "company_name": {
      "type": "string"
    },
    "company_email": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["full_time", "part_time", "internship", "contract", "remote"]
    },
    "location": {
      "type": "string"
    },
    "salary_range": {
      "type": "string"
    },
    "required_skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed", "filled"],
      "default": "open"
    },
    "application_count": {
      "type": "number",
      "default": 0
    },
    "deadline": {
      "type": "string",
      "format": "date"
    }
  },
  "required": ["title"]
}
