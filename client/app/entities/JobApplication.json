{
  "name": "JobApplication",
  "type": "object",
  "properties": {
    "job_id": {
      "type": "string"
    },
    "job_title": {
      "type": "string"
    },
    "applicant_email": {
      "type": "string"
    },
    "applicant_name": {
      "type": "string"
    },
    "company_email": {
      "type": "string"
    },
    "cover_letter": {
      "type": "string"
    },
    "resume_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["submitted", "reviewing", "shortlisted", "rejected", "accepted"],
      "default": "submitted"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["job_id", "applicant_email"]
}
