{
  "name": "SkillMatch",
  "type": "object",
  "properties": {
    "user_a_email": {
      "type": "string"
    },
    "user_a_name": {
      "type": "string"
    },
    "user_b_email": {
      "type": "string"
    },
    "user_b_name": {
      "type": "string"
    },
    "skill_a_teaches": {
      "type": "string"
    },
    "skill_b_teaches": {
      "type": "string"
    },
    "match_score": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": ["suggested", "accepted", "declined", "completed"],
      "default": "suggested"
    }
  },
  "required": ["user_a_email", "user_b_email"]
}
